{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Javis",
  "version": "0.1.0",
  "identifier": "app.javis.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build:bundle",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Javis",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "publisher": "Javis Contributors",
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "upgradeCode": "b443f13b-df09-5c55-b75e-c66eed973e79"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": {
      "../../../node_modules/.pnpm/opencode-windows-x64@1.15.10/node_modules/opencode-windows-x64/bin/opencode.exe": "bin/opencode-windows-x64/opencode.exe",
      "../../../node_modules/.pnpm/opencode-windows-x64-baseline@1.15.10/node_modules/opencode-windows-x64-baseline/bin/opencode.exe": "bin/opencode-windows-x64-baseline/opencode.exe",
      "sidecar/browser/dist/index.js": "sidecar/browser/dist/index.js",
      "../../../node_modules/.pnpm/playwright@1.60.0/node_modules/playwright/": "sidecar/browser/node_modules/playwright/",
      "../../../node_modules/.pnpm/playwright-core@1.60.0/node_modules/playwright-core/": "sidecar/browser/node_modules/playwright-core/",
      "../../../scripts/local-vision-worker.cmd": "scripts/local-vision-worker.cmd",
      "../../../scripts/local-vision-worker.mjs": "scripts/local-vision-worker.mjs",
      "../../../scripts/local-vision-onnx-adapter.mjs": "scripts/local-vision-onnx-adapter.mjs",
      "../../../artifacts/local-vision/yolo26n-ui.onnx": "models/local-vision/yolo26n-ui.onnx",
      "../../../artifacts/local-vision/node_modules/onnxruntime-common/": "scripts/node_modules/onnxruntime-common/",
      "../../../artifacts/local-vision/node_modules/onnxruntime-node/": "scripts/node_modules/onnxruntime-node/",
      "../../../artifacts/local-vision/node-runtime/": "bin/node/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
