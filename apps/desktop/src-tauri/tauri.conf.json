{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Javis",
  "version": "0.1.0",
  "identifier": "app.javis.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Javis",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 680,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis"
    ],
    "publisher": "Javis Contributors",
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "upgradeCode": "b443f13b-df09-5c55-b75e-c66eed973e79"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "resources": {
      "../../../node_modules/.pnpm/opencode-windows-x64@1.15.10/node_modules/opencode-windows-x64/bin/opencode.exe": "bin/opencode-windows-x64/opencode.exe",
      "../../../node_modules/.pnpm/opencode-windows-x64-baseline@1.15.10/node_modules/opencode-windows-x64-baseline/bin/opencode.exe": "bin/opencode-windows-x64-baseline/opencode.exe"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
